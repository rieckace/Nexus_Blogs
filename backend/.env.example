# API server
PORT=4000

# MongoDB
# Default used by code if unset: mongodb://127.0.0.1:27017/Main_Blog
MONGO_URI=mongodb://127.0.0.1:27017/Main_Blog

# Client URL allowed by CORS (add your deployed URL if needed)
CLIENT_URL=http://localhost:3000

# Email (used by /subscribe and /con/contact)
# Use a Gmail App Password if 2FA is enabled.
EMAIL_USER=
EMAIL_PASS=
